# Copy to .env for local development. Never commit .env.
#
# Private constants only — public deploy config lives in lib/constants.ts.
# Read secrets via getServerEnv() from @lib/env-server (server-side only).
#
# Requires NPM_TOKEN in your shell for `pnpm install` (GitLab registry auth).

# ---------------------------------------------------
# Private secrets and variables for server-side usage
# ---------------------------------------------------

# API_SECRET_KEY=
# WEBHOOK_SIGNING_SECRET=
# API_KEY=                          # /api/revalidate — x-api-key header
# SANITY_PREVIEW_TOKEN=             # /api/preview — enables draft mode
# EDEN_PAYMENT_CLIENT_ID=
# EDEN_PAYMENT_CLIENT_SECRET=

# Sanity GROQ (server-only — lib/sanity/direct-fetch.ts)
# EDEN_SANITY_PROJECT_ID=
# EDEN_SANITY_DATASET=
# EDEN_SANITY_API_DEVELOPER_TOKEN=

# ------------------------------------
# Public variables for use client-side
# ------------------------------------

# Eden API (CMS + platform)
# NEXT_PUBLIC_EDEN_API_URL=
# NEXT_PUBLIC_EDEN_OAUTH_URL=
# NEXT_PUBLIC_EDEN_HUB_ORIGIN=

# Algolia (search-only keys — safe in browser)
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Sanity image CDN
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=
# NEXT_PUBLIC_SANITY_PROJECT_SET=

# Optional
# NEXT_PUBLIC_IMAGE_OPTIMISATION_URL=
# NEXT_PUBLIC_DESIGN_SYSTEM=

# Sentry (error monitoring)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DATASET=eden-test
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
